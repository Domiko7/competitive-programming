{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run (Fast)",
            "type": "shell",
            "command": "/bin/bash",
            "args": [
                "-c",
                "/opt/homebrew/bin/g++-15 -O3 -std=c++20 \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\" && \"${fileDirname}/${fileBasenameNoExtension}\""
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "C/C++: g++-15 build active file",
            "type": "cppbuild",
            "command": "/opt/homebrew/bin/g++-15",
            "args": [
                "-g",
                "-std=c++20",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "group": "build",
            "detail": "Debugger uses this."
        }
    ]
}